# FairShare Environment Configuration
# Copy this file to .env and fill in your actual values

# RestDB.io Configuration (optional - uses local database.json if not set)
RESTDB_URL=[url]
RESTDB_KEY=[key]

# Email Service Configuration (optional - Resend.com)
RESEND_API_KEY=[key]
EMAIL_FROM=[Name] <Email>

# Server Configuration
PORT=3000
